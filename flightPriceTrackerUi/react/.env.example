# Cluster connection (C3 system paths)
VITE_C3_URL=https://your-cluster.c3.ai
VITE_C3_ENV=yourenv
VITE_C3_APP=flightpricetrackerui

# Local flights proxy (OAuth client_credentials)
# NOT VITE_* prefixed — never bundled into the browser.
# Get client_id and client_secret from your team (see archived/secret-config.md).
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
API_BASE_URL=https://your-cluster.c3.ai/yourenv/flightpricetrackerapi/flights
